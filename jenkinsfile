pipeline {

    agent any


    environment {

        IMAGE_NAME = "dockerwillwu1021/hello-web"

    }


    stages {


        stage('Build Docker Image') {

            steps {

                script {


                    // 获取当前 Git commit hash
                    def commitId = sh(
                        script: "git rev-parse --short HEAD",
                        returnStdout: true
                    ).trim()


                    // 保存 IMAGE_TAG 给后续 stage 使用
                    env.IMAGE_TAG = commitId


                    echo "================================"
                    echo "Building Docker Image"
                    echo "${IMAGE_NAME}:${IMAGE_TAG}"
                    echo "================================"


                    sh """
                    docker build \
                    -t ${IMAGE_NAME}:${IMAGE_TAG} .
                    """


                }

            }

        }



        stage('Run Container Test') {

            steps {

                echo "Testing Docker Image"

                sh """

                docker run \
                -d \
                --network cicd-net \
                --name test-container \
                ${IMAGE_NAME}:${IMAGE_TAG}


                sleep 5


                curl test-container:8080


                docker stop test-container
                docker rm test-container

                """

            }

        }



        stage('Push Image') {

            steps {


                withCredentials([

                    usernamePassword(
                        credentialsId: 'dockerhub',
                        usernameVariable: 'DOCKER_USER',
                        passwordVariable: 'DOCKER_PASS'
                    )

                ]) {


                    echo "Login Docker Hub"


                    sh '''

                    echo $DOCKER_PASS | docker login \
                    -u $DOCKER_USER \
                    --password-stdin

                    echo "Create latest tag"
                    docker tag \
                    ${IMAGE_NAME}:${IMAGE_TAG} \
                    ${IMAGE_NAME}:latest

                    echo "Push version tag"



                    docker push \
                    ${IMAGE_NAME}:${IMAGE_TAG}



                    echo "Push latest tag"



                    docker push \
                    ${IMAGE_NAME}:latest



                    docker logout

                    '''


                }


            }

        }
        
        stage('Debug SSH') {
            steps {
                sh '''
                whoami
                echo $HOME
                ls -la ~/.ssh || true
                ssh -v willwu@host.docker.internal exit
                '''
            }
        }
        stage('Deploy') {

            steps {

                sh '''
                ssh willwu@host.docker.internal "
                cd ~/deploy &&
                docker compose pull &&
                docker compose up -d
                "
                '''

            }
        }

        stage('Finish') {

            steps {


                echo "Pipeline finished successfully"


            }

        }


    }


}

