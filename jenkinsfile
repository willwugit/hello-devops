pipeline {

    agent any

    stages {

        stage('Build Docker Image') {
           steps {
               sh '''
               docker build -t hello-app .
               '''
    }
}

        stage('Run Docker Container') {
            steps {
                sh '''
                docker run --rm hello-app
                '''
            }
        }


        stage('Finish') {
            steps {
                echo 'Pipeline finished'
            }
        }

    }
}