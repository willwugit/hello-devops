pipeline {

    agent any

    stages {

        stage('Build Docker Image') {
           steps {
               sh '''
               docker build -t hello-app .
               '''
    }
}

        stage('Run Script') {
            steps {
                sh '''
                chmod +x hello.sh
                ./hello.sh
                '''
            }
        }


        stage('Finish') {
            steps {
                echo 'Pipeline finished'
            }
        }

    }
}